# ============================================================
# .env — OpenClaw Lark Agent
# Copy to ~/.openclaw/.env and fill in your values
# NEVER commit this file to git
# ============================================================

# ── Lark App Credentials ────────────────────────────────────
# Get from: https://open.larksuite.com/app → Your App → Credentials
LARK_APP_ID=cli_xxxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_ENCRYPT_KEY=                          # Optional, leave blank to skip

# ── LLM APIs ────────────────────────────────────────────────
# Moonshot (Kimi): https://platform.moonshot.cn/
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek (fallback): https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Storage ─────────────────────────────────────────────────
OPENCLAW_WORKSPACE=/data/openclaw/workspace   # USB SSD path
OPENCLAW_LOGS=/data/openclaw/logs

# ── Cloudflare Tunnel ───────────────────────────────────────
# Set after running: cloudflared tunnel create openclaw
CLOUDFLARE_TUNNEL_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLOUDFLARE_TUNNEL_SECRET=

# ── Job Search APIs (Phase 2) ───────────────────────────────
# LinkedIn unofficial scrape via RapidAPI
RAPIDAPI_KEY=                              # For LinkedIn Jobs API
# Adzuna API (free tier, good coverage)
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# ── User Config ─────────────────────────────────────────────
USER_LARK_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxx  # Your Lark user open_id
USER_TIMEZONE=America/Toronto
USER_TARGET_COUNTRY=Canada
USER_FRENCH_TARGET_LEVEL=B1
